{
  "name": "eve-docs",
  "version": "0.1.0",
  "private": true,
  "description": "Eve 中文文档站，基于 Next.js 与 Fumadocs。",
  "type": "module",
  "scripts": {
    "dev": "fumadocs-mdx && next dev --turbo",
    "build": "fumadocs-mdx && next build",
    "start": "next start",
    "docs:generate": "fumadocs-mdx"
  },
  "dependencies": {
    "fumadocs-core": "16.9.1",
    "fumadocs-mdx": "14.0.4",
    "fumadocs-ui": "16.9.1",
    "lucide-react": "1.16.0",
    "next": "16.2.6",
    "next-themes": "0.4.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "shiki": "4.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@types/mdx": "2.0.13",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "postcss": "8.5.15",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3"
  }
}
